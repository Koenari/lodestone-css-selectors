            "Name": "string"
        }
    },
    "MATERIA_3": {
        "selector": "ul.db-tooltip__materia > li:nth-child(3) > div:nth-child(2)",
        "regex": "(?P<Name>.*)<br/>",
        "type": {
            "Name": "string"
        }
    },
    "MATERIA_4": {
        "selector": "ul.db-tooltip__materia > li:nth-child(4) > div:nth-child(2)",
        "regex": "(?P<Name>.*)<br/>",
        "type": {
            "Name": "string"
        }

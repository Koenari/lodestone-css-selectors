{
    "NAME": {
        "selector": ".db-tooltip__item__name",
        "type": "string"
    },
    "DB_LINK": {
        "selector": ".db-tooltip__bt_item_detail > a:nth-child(1)",
        "type": "string"
    },
    "MIRAGE_NAME": {
        "selector": ".db-tooltip > div:nth-child(1) > div:nth-child(1) > div:nth-child(1) > div:nth-child(1) > div:nth-child(2) > div:nth-child(3) > p:nth-child(2)",
        "type": "string"
    },
    "MIRAGE_DB_LINK": {
        "selector": ".db-tooltip > div:nth-child(1) > div:nth-child(1) > div:nth-child(1) > div:nth-child(1) > div:nth-child(2) > div:nth-child(3) > p:nth-child(2) > a:nth-child(1)",
        "type": "string"
    },
    "STAIN": {
        "selector": "div:nth-child(4) > div:nth-child(1) > div:nth-child(1) > div:nth-child(5) > div:nth-child(3) > div:nth-child(1) > a:nth-child(1)",
        "type": "string"
    },
